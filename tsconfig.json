{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "types": ["node"],
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "$src/*": ["./src/*"],
      "$lib/*": ["./src/lib/*"],
      "$middleware/*": ["./src/middleware/*"],
      "$routes/*": ["./src/routes/*"]
    }
  }
}
