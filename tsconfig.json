{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "$src/*": ["./src/*"],
      "$lib/*": ["./src/lib/*"],
      "$middleware/*": ["./src/middleware/*"],
      "$routes/*": ["./src/routes/*"],
    },
  },
}
