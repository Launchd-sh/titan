# Copy to .env and fill in values before running.

# Server
PORT=8080

# PostgreSQL — matches the docker-compose service.
# If running the app inside Docker too, change localhost → postgres.
DATABASE_URL=postgresql://titan:titan@localhost:5432/titan

# JWT — must be a long, random secret in production.
JWT_SECRET=some_long_secret_here_please_change_me

# Token lifetimes (optional — units: ms, s, m, h, d)
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL=7d
